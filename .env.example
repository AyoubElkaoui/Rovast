# ====================================================================
#  Storingsformulier — environment variables
#  Lokaal: kopieer naar .env  (NIET committen).
#  Vercel: zet deze onder Settings → Environment Variables (Production + Preview).
# ====================================================================

# --- Database (Neon PostgreSQL) ---
# DATABASE_URL = de POOLED connectie (host bevat "-pooler"). Door de app gebruikt.
# DIRECT_URL   = de DIRECTE/unpooled connectie. Door Prisma gebruikt voor migraties
#                (prisma db push / migrate). Beide krijg je in het Neon-dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require

# --- Interne afscherming ---
# Gedeeld wachtwoord voor de interne pagina's (/intern). Kies iets sterks.
INTERN_WACHTWOORD=kies-een-sterk-wachtwoord

# --- Basis-URL (optioneel) ---
# Gebruikt voor de "open de melding"-link in de mail. Leeg laten = automatisch
# de huidige deploy-URL. Op productie aanrader om je vaste domein te zetten.
APP_BASE_URL=https://rovast.vercel.app

# --- Resend e-mailconfiguratie ---
# API-sleutel van je Resend-account. NOOIT in code/repo zetten.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Ontvanger van de meldingsmail (met interne aanvullink).
# LET OP: met from = onboarding@resend.dev (geen geverifieerd domein) levert
# Resend ALLEEN aan de account-eigenaar: ayoub@itfin.nl.
STORING_TO=ayoub@itfin.nl

# Afzender. Zonder geverifieerd domein MOET dit het Resend-testadres zijn.
STORING_FROM=Storingsformulier <onboarding@resend.dev>
