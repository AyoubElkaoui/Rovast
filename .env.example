# --- Resend e-mailconfiguratie voor het storingsformulier ---

# API-sleutel van je Resend-account. Aanmaken op https://resend.com/api-keys
# NB: zet de echte key NOOIT in dit voorbeeldbestand of in de code.
# Lokaal in .env.local, in productie in Vercel → Settings → Environment Variables.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Ontvanger van de storingsmeldingen.
# LET OP: zolang we from = onboarding@resend.dev gebruiken (geen geverifieerd
# domein), staat Resend ALLEEN toe te sturen naar de account-eigenaar.
# Doorsturen naar André gaat via een forward-regel in de itfin.nl-mailbox.
STORING_TO=ayoub@itfin.nl

# Afzender. LET OP: zonder geverifieerd domein MOET dit het Resend-testadres zijn,
# anders weigert Resend de mail. Formaat: "Naam <adres@domein.nl>".
STORING_FROM=Storingsformulier <onboarding@resend.dev>
